<Window
  x:Class="LLMeta.App.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="LLMeta"
  Height="400"
  Width="600"
  MinHeight="300"
  MinWidth="400"
  WindowStartupLocation="CenterScreen"
>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
      Grid.Row="0"
      Text="LLMeta Desktop Application Template"
      FontSize="18"
      FontWeight="SemiBold"
      Margin="0,0,0,16"
    />

    <StackPanel Grid.Row="1" Margin="0,0,0,16">
      <TextBlock Text="Sample Text:" FontWeight="SemiBold" Margin="0,0,0,4" />
      <TextBox
        Text="{Binding SampleText, UpdateSourceTrigger=PropertyChanged}"
        Height="32"
        Padding="4"
      />

      <TextBlock Text="Settings:" FontWeight="SemiBold" Margin="0,16,0,8" />

      <CheckBox
        Content="Start with Windows"
        IsChecked="{Binding StartWithWindows}"
        Margin="0,0,0,4"
      />
      <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}" Margin="0,0,0,4" />
    </StackPanel>

    <StackPanel Grid.Row="2" Orientation="Horizontal">
      <Button Content="Save Settings" Width="120" Command="{Binding SaveSettingsCommand}" />
    </StackPanel>

    <TextBlock
      Grid.Row="2"
      HorizontalAlignment="Right"
      VerticalAlignment="Center"
      Text="{Binding StatusMessage}"
      Foreground="Gray"
    />
  </Grid>
</Window>
