{
  "tasks": [
    {
      "name": "format",
      "command": "dotnet",
      "args": [
        "csharpier",
        "format",
        "."
      ]
    },
    {
      "name": "lint",
      "command": "dotnet",
      "args": [
        "build",
        "LLMeta.sln"
      ]
    },
    {
      "name": "restage",
      "command": "git",
      "args": [
        "add",
        "-u"
      ]
    }
  ],
  "groups": [
    {
      "name": "pre-commit",
      "tasks": [
        "format",
        "lint",
        "restage"
      ]
    }
  ]
}
